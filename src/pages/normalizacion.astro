---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BaseLayout title="Evidencias de Modelado | JGarciaOs">
  <article class="post">
    <h1 class="post-title">Evidencias de Modelado - Módulo 1</h1>
    <div class="post-meta">
      <span class="post-date">2025-02-19</span>
      <span class="post-author">:: JGarciaOs</span>
    </div>

    <div class="post-content">

      <section style="margin-top: 2rem;">

  </article>
</BaseLayout>

<style>
  .evidence-img {
    width: 100%;
    height: auto;
    border: 1px solid #444;
    margin: 1rem 0 2rem 0;
    display: block;
  }
  h3 {
    color: var(--global-color-primary, #2ecc71);
  }
</style>